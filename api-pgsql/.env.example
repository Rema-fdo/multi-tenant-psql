# Copy to .env before running.
PORT=4000

# JWT signing. Change this to any long random string.
JWT_SECRET=change-me-to-something-random
JWT_EXPIRES_IN=1d

# Super admin is not stored in the database. It is a fixed operator account.
SUPER_ADMIN_USERNAME=superadmin
SUPER_ADMIN_PASSWORD=super-secret-password

# PostgreSQL connection string. Local example shown; paste your hosted
# connection string here instead (Neon, Supabase, RDS, etc.). The database
# name is the last path segment (feature_flags below).
DATABASE_URL=postgresql://neondb_owner:npg_pFQWJzLr8ay2@ep-autumn-rice-adb0s1pu.c-2.us-east-1.aws.neon.tech/neondb?sslmode=require

# Set to true for hosted providers that require TLS (most managed Postgres do).
DATABASE_SSL=true

# Where the frontend runs, for CORS.
WEB_ORIGIN=http://localhost:3000
